{
  "name": "@mukundakatta/bytes-mcp",
  "version": "0.1.0",
  "mcpName": "io.github.MukundaKatta/bytes",
  "description": "MCP server: parse and format byte sizes \u2014 1024 \u2194 '1 KB', '1.5 MB' \u2194 1572864.",
  "type": "module",
  "bin": {
    "mcp-bytes": "dist/server.js"
  },
